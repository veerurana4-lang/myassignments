import pandas as pd
import streamlit as st
import plotly.express as px

st.set_page_config(page_title="EduPro Analytics Dashboard", layout="wide")

st.title("EduPro Learner Demographics & Enrollment Analytics")

# Load datasets
users = pd.read_csv("users.csv")
courses = pd.read_csv("courses.csv")
transactions = pd.read_csv("transactions.csv")

# Merge datasets
merged_df = transactions.merge(users, on="UserID")
merged_df = merged_df.merge(courses, on="CourseID")

# Create Age Groups
bins = [0, 18, 25, 35, 45, 100]
labels = ["<18", "18-25", "26-35", "36-45", "45+"]
merged_df["Age Group"] = pd.cut(merged_df["Age"], bins=bins, labels=labels)

# Sidebar Filters
st.sidebar.header("Filters")

selected_gender = st.sidebar.multiselect(
    "Select Gender",
    options=merged_df["Gender"].unique(),
    default=merged_df["Gender"].unique()
)

selected_category = st.sidebar.multiselect(
    "Select Course Category",
    options=merged_df["CourseCategory"].unique(),
    default=merged_df["CourseCategory"].unique()
)

selected_level = st.sidebar.multiselect(
    "Select Course Level",
    options=merged_df["CourseLevel"].unique(),
    default=merged_df["CourseLevel"].unique()
)

# Apply Filters
filtered_df = merged_df[
    (merged_df["Gender"].isin(selected_gender)) &
    (merged_df["CourseCategory"].isin(selected_category)) &
    (merged_df["CourseLevel"].isin(selected_level))
]

# KPIs
st.subheader("Key Performance Indicators")

col1, col2, col3 = st.columns(3)

col1.metric("Total Users", filtered_df["UserID"].nunique())
col2.metric("Total Enrollments", filtered_df["TransactionID"].count())
col3.metric("Average Courses per User", round(filtered_df["TransactionID"].count() / filtered_df["UserID"].nunique(), 2))

# Age Group Distribution
st.subheader("Age Group Distribution")
age_chart = filtered_df.groupby("Age Group").size().reset_index(name="Count")
fig1 = px.bar(age_chart, x="Age Group", y="Count", title="Enrollments by Age Group")
st.plotly_chart(fig1, use_container_width=True)

# Gender Distribution
st.subheader("Gender Distribution")
fig2 = px.pie(filtered_df, names="Gender", title="Gender Participation")
st.plotly_chart(fig2, use_container_width=True)

# Course Category Popularity
st.subheader("Course Category Popularity")
category_chart = filtered_df.groupby("CourseCategory").size().reset_index(name="Enrollments")
fig3 = px.bar(category_chart, x="CourseCategory", y="Enrollments", title="Popular Course Categories")
st.plotly_chart(fig3, use_container_width=True)

# Course Level Distribution
st.subheader("Course Level Distribution")
level_chart = filtered_df.groupby(["CourseLevel", "Gender"]).size().reset_index(name="Count")
fig4 = px.bar(level_chart, x="CourseLevel", y="Count", color="Gender", barmode="group")
st.plotly_chart(fig4, use_container_width=True)

# Heatmap Table
st.subheader("Age Group vs Course Category")
heatmap_data = pd.crosstab(filtered_df["Age Group"], filtered_df["CourseCategory"])
st.dataframe(heatmap_data)

# Key Insights
st.subheader("Project Insights")

st.write("• The 18-25 age group contributes the highest enrollments on the platform.")
st.write("• Beginner-level courses are more popular among learners.")
st.write("• Course preferences vary across gender and age groups.")
st.write("• Certain categories attract higher engagement levels.")
